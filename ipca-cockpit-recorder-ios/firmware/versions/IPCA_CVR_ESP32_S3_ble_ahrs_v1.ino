class IPCABLEServerCallbacks : public BLEServerCallbacks {
  void onConnect(BLEServer *server) override {
    bleCentralConnected = true;
    ipadReady = true;
    screenDirty = true;
  }

  void onDisconnect(BLEServer *server) override {
    bleCentralConnected = false;
    ipadReady = false;
    screenDirty = true;
    server->getAdvertising()->start();
  }
};

String buildAHRSLine() {
  char line[96];
  snprintf(
    line,
    sizeof(line),
    "AHRS,ROLL=%.1f,PITCH=%.1f,YAW=%.1f,ACC=%.2f,MAGHDG=%.1f",
    rollDeg,
    pitchDeg,
    yawDeg,
    accTotal,
    magHeadingDeg
  );
  return String(line);
}

void notifyAHRSLine(const String &line) {
  if (!bleCentralConnected || ahrsCharacteristic == nullptr) return;
  ahrsCharacteristic->setValue((uint8_t *)line.c_str(), line.length());
  ahrsCharacteristic->notify();
}

void setupBLE() {
  BLEDevice::init(BLE_DEVICE_NAME);

  bleServer = BLEDevice::createServer();
  bleServer->setCallbacks(new IPCABLEServerCallbacks());

  BLEService *service = bleServer->createService(BLE_SERVICE_UUID);
  ahrsCharacteristic = service->createCharacteristic(
    BLE_AHRS_CHARACTERISTIC_UUID,
    BLECharacteristic::PROPERTY_READ | BLECharacteristic::PROPERTY_NOTIFY
  );
  ahrsCharacteristic->addDescriptor(new BLE2902());
  ahrsCharacteristic->setValue(buildAHRSLine().c_str());

  service->start();

  BLEAdvertising *advertising = BLEDevice::getAdvertising();
  advertising->addServiceUUID(BLE_SERVICE_UUID);
  advertising->setScanResponse(true);
  advertising->setMinPreferred(0x06);
  advertising->setMinPreferred(0x12);
  BLEDevice::startAdvertising();

  Serial.println("BLE IPCA-CVR advertising");
}

void quatToEuler(float qr, float qi, float qj, float qk) {
  yawDeg = atan2(2.0f * (qi * qj + qk * qr),
                 qi * qi - qj * qj - qk * qk + qr * qr) * 180.0f / PI;

  pitchDeg = asin(-2.0f * (qi * qk - qj * qr)) * 180.0f / PI;

  rollDeg = atan2(2.0f * (qj * qk + qi * qr),
                  -qi * qi - qj * qj + qk * qk + qr * qr) * 180.0f / PI;
}

void setupAHRS() {
  Wire.begin(BNO_SDA, BNO_SCL);
  delay(250);

  Serial.println("Searching for BNO085...");

  if (bno08x.begin_I2C(0x4A, &Wire)) {
    Serial.println("BNO085 FOUND at 0x4A");
  } else if (bno08x.begin_I2C(0x4B, &Wire)) {
    Serial.println("BNO085 FOUND at 0x4B");
  } else {
    Serial.println("BNO085 NOT FOUND at 0x4A or 0x4B");
    ahrsReady = false;
    screenDirty = true;
    return;
  }

  if (!bno08x.enableReport(SH2_ROTATION_VECTOR, 10000)) {
    Serial.println("ROTATION VECTOR FAILED");
    ahrsReady = false;
    screenDirty = true;
    return;
  }

  bno08x.enableReport(SH2_LINEAR_ACCELERATION, 20000);
  bno08x.enableReport(SH2_MAGNETIC_FIELD_CALIBRATED, 20000);

  ahrsReady = true;
  screenDirty = true;
}

void readAHRS() {
  if (!ahrsReady) return;

  if (bno08x.wasReset()) {
    bno08x.enableReport(SH2_ROTATION_VECTOR, 10000);
    bno08x.enableReport(SH2_LINEAR_ACCELERATION, 20000);
    bno08x.enableReport(SH2_MAGNETIC_FIELD_CALIBRATED, 20000);
  }

  while (bno08x.getSensorEvent(&sensorValue)) {
    if (sensorValue.sensorId == SH2_ROTATION_VECTOR) {
      quatToEuler(
        sensorValue.un.rotationVector.real,
        sensorValue.un.rotationVector.i,
        sensorValue.un.rotationVector.j,
        sensorValue.un.rotationVector.k
      );
    }

    if (sensorValue.sensorId == SH2_LINEAR_ACCELERATION) {
      accX = sensorValue.un.linearAcceleration.x;
      accY = sensorValue.un.linearAcceleration.y;
      accZ = sensorValue.un.linearAcceleration.z;
      accTotal = sqrt(accX * accX + accY * accY + accZ * accZ);
    }

    if (sensorValue.sensorId == SH2_MAGNETIC_FIELD_CALIBRATED) {
      magX = sensorValue.un.magneticField.x;
      magY = sensorValue.un.magneticField.y;
      magZ = sensorValue.un.magneticField.z;

      magHeadingDeg = atan2(magY, magX) * 180.0f / PI;
      if (magHeadingDeg < 0) magHeadingDeg += 360.0f;
    }
  }

  if (millis() - lastAHRSPrint > 250) {
    Serial.print("AHRS,ROLL=");
    Serial.print(rollDeg, 1);
    Serial.print(",PITCH=");
    Serial.print(pitchDeg, 1);
    Serial.print(",YAW=");
    Serial.print(yawDeg, 1);
    Serial.print(",ACC=");
    Serial.print(accTotal, 2);
    Serial.print(",MAGHDG=");
    Serial.println(magHeadingDeg, 1);

    notifyAHRSLine(buildAHRSLine());

    lastAHRSPrint = millis();
  }
}

